{
  "workspace": {
    "path": "workspace"
  },
  "gateway": {
    "port": 18790
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "token": "",
      "allowFrom": [],
      "chatIds": []
    }
  },
  "agent": {
    "provider": "openai",
    "modelId": "gpt-4.1-mini",
    "systemPrompt": "You are nanobot, a personal AI assistant.",
    "thinkingLevel": "off",
    "temperature": 0.1,
    "maxTokens": 4096,
    "toolExecution": "parallel",
    "transport": "sse",
    "maxRetryDelayMs": 60000,
    "sessionStore": {
      "type": "file",
      "path": "sessions"
    }
  },
  "logging": {
    "level": "info"
  }
}
